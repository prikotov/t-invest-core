#!/usr/bin/env php
<?php

declare(strict_types=1);

use Symfony\Component\Console\Application;
use TInvest\Skill\Command\MainCommand;
use TInvest\Skill\Command\PortfolioPositionsCommand;

if (file_exists(__DIR__ . '/../vendor/autoload.php')) {
    require __DIR__ . '/../vendor/autoload.php';
} else {
    require __DIR__ . '/../../../autoload.php';
}

$container = require __DIR__ . '/../config/container.php';

$application = new Application('T-Invest Skill', '1.0.0');
$application->add($container->get(MainCommand::class));
$application->add($container->get(PortfolioPositionsCommand::class));

exit($application->run());
