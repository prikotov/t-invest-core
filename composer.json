{
    "name": "prikotov/t-invest-core",
    "description": "CLI tool for T-Invest API - portfolio management and trading",
    "type": "library",
    "license": "MIT",
    "keywords": ["t-invest", "invest", "api", "cli", "console", "trading", "portfolio", "stocks", "bonds"],
    "authors": [
        {
            "name": "Dmitry Prikotov",
            "email": "prikotov@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "TInvest\\Core\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TInvest\\Core\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.4",
        "ext-json": "*",
        "guzzlehttp/guzzle": "^7.8",
        "monolog/monolog": "^3.5",
        "psr/log": "^3.0",
        "symfony/config": "^8.0",
        "symfony/console": "^8.0",
        "symfony/dependency-injection": "^8.0",
        "symfony/dotenv": "^8.0",
        "symfony/yaml": "^8.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.10",
        "phpunit/phpunit": "^10.0",
        "squizlabs/php_codesniffer": "^3.7",
        "vimeo/psalm": "^5.0|^6.0",
        "prikotov/coding-standard": "@dev"
    },
    "bin": [
        "bin/t-invest"
    ],
    "config": {
        "sort-packages": true,
        "platform-check": true
    },
    "scripts": {
        "test": "phpunit",
        "cs-check": "phpcs",
        "cs-fix": "phpcbf",
        "stan": "phpstan analyse",
        "psalm": "psalm"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/prikotov/coding-standard"
        }
    ],
    "extra": {
        "branch-alias": {
            "dev-main": "1.0-dev"
        }
    }
}
